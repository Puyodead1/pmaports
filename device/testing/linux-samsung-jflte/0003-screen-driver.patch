+#define MAGNA_OCTA_MID_COEFFICIENT	64
+#define MAGNA_OCTA_MID_DENOMINATOR	320
+
+static int char_to_int(char data1)
+{
+	int cal_data;
+
+	if (data1 & 0x80) {
+		cal_data = data1 & 0x7F;
+		cal_data *= -1;
+	} else
+		cal_data = data1;
+
+	return cal_data;
+}
+
+static int char_to_int_v255(char data1, char data2)
+{
+	int cal_data;
+
+	if (data1)
+		cal_data = data2 * -1;
+	else
+		cal_data = data2;
+
+	return cal_data;
+}
+
+#define v255_coefficient 72
+#define v255_denominator 860
+static int v255_adjustment(struct SMART_DIM *pSmart)
+{
+	unsigned long long result_1, result_2, result_3, result_4;
+	int add_mtp;
+	int LSB;
+	int v255_value;
+
+	v255_value = (V255_300CD_R_MSB_20 << 8) | V255_300CD_R_LSB_20;
+	LSB = char_to_int_v255(pSmart->MTP.R_OFFSET.OFFSET_255_MSB,
+				pSmart->MTP.R_OFFSET.OFFSET_255_LSB);
+	add_mtp = LSB + v255_value;
+	result_1 = result_2 = (v255_coefficient+add_mtp) << BIT_SHIFT;
+	do_div(result_2, v255_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->RGB_OUTPUT.R_VOLTAGE.level_255 = result_4;
+	pSmart->RGB_OUTPUT.R_VOLTAGE.level_0 = S6E8FA_VREG0_REF;
+
+	v255_value = (V255_300CD_G_MSB_20 << 8) | V255_300CD_G_LSB_20;
+	LSB = char_to_int_v255(pSmart->MTP.G_OFFSET.OFFSET_255_MSB,
+				pSmart->MTP.G_OFFSET.OFFSET_255_LSB);
+	add_mtp = LSB + v255_value;
+	result_1 = result_2 = (v255_coefficient+add_mtp) << BIT_SHIFT;
+	do_div(result_2, v255_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->RGB_OUTPUT.G_VOLTAGE.level_255 = result_4;
+	pSmart->RGB_OUTPUT.G_VOLTAGE.level_0 = S6E8FA_VREG0_REF;
+
+	v255_value = (V255_300CD_B_MSB_20 << 8) | V255_300CD_B_LSB_20;
+	LSB = char_to_int_v255(pSmart->MTP.B_OFFSET.OFFSET_255_MSB,
+				pSmart->MTP.B_OFFSET.OFFSET_255_LSB);
+	add_mtp = LSB + v255_value;
+	result_1 = result_2 = (v255_coefficient+add_mtp) << BIT_SHIFT;
+	do_div(result_2, v255_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->RGB_OUTPUT.B_VOLTAGE.level_255 = result_4;
+	pSmart->RGB_OUTPUT.B_VOLTAGE.level_0 = S6E8FA_VREG0_REF;
+
+
+	return 0;
+}
+
+static void v255_hexa(int *index, struct SMART_DIM *pSmart, char *str)
+{
+	unsigned long long result_1, result_2, result_3;
+
+	result_1 = S6E8FA_VREG0_REF -
+		(pSmart->GRAY.TABLE[index[V255_INDEX]].R_Gray);
+	result_2 = result_1 * v255_denominator;
+	do_div(result_2, S6E8FA_VREG0_REF);
+	result_3 = result_2  - v255_coefficient;
+	str[0] = (result_3 & 0xff00) >> 8;
+	str[1] = result_3 & 0xff;
+
+	result_1 = S6E8FA_VREG0_REF -
+		(pSmart->GRAY.TABLE[index[V255_INDEX]].G_Gray);
+	result_2 = result_1 * v255_denominator;
+	do_div(result_2, S6E8FA_VREG0_REF);
+	result_3 = result_2  - v255_coefficient;
+	str[2] = (result_3 & 0xff00) >> 8;
+	str[3] = result_3 & 0xff;
+
+	result_1 = S6E8FA_VREG0_REF -
+			(pSmart->GRAY.TABLE[index[V255_INDEX]].B_Gray);
+	result_2 = result_1 * v255_denominator;
+	do_div(result_2, S6E8FA_VREG0_REF);
+	result_3 = result_2  - v255_coefficient;
+	str[4] = (result_3 & 0xff00) >> 8;
+	str[5] = result_3 & 0xff;
+
+}
+
+static int vt_coefficient[] = {
+	0, 12, 24, 36, 48,
+	60, 72, 84, 96, 108,
+	138, 148, 158, 168,
+	178, 186,
+};
+#define vt_denominator 860
+static int vt_adjustment(struct SMART_DIM *pSmart)
+{
+	unsigned long long result_1, result_2, result_3, result_4;
+	int add_mtp;
+	int LSB;
+
+	LSB = char_to_int(pSmart->MTP.R_OFFSET.OFFSET_1);
+	add_mtp = LSB + VT_300CD_R_20;
+	result_1 = result_2 = vt_coefficient[LSB] << BIT_SHIFT;
+	do_div(result_2, vt_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->GRAY.VT_TABLE.R_Gray = result_4;
+
+	LSB = char_to_int(pSmart->MTP.G_OFFSET.OFFSET_1);
+	add_mtp = LSB + VT_300CD_G_20;
+	result_1 = result_2 = vt_coefficient[LSB] << BIT_SHIFT;
+	do_div(result_2, vt_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->GRAY.VT_TABLE.G_Gray = result_4;
+
+	LSB = char_to_int(pSmart->MTP.B_OFFSET.OFFSET_1);
+	add_mtp = LSB + VT_300CD_B_20;
+	result_1 = result_2 = vt_coefficient[LSB] << BIT_SHIFT;
+	do_div(result_2, vt_denominator);
+	result_3 = (S6E8FA_VREG0_REF * result_2) >> BIT_SHIFT;
+	result_4 = S6E8FA_VREG0_REF - result_3;
+	pSmart->GRAY.VT_TABLE.B_Gray = result_4;
+
+
+	return 0;
+
+}
+
+static void vt_hexa(int *index, struct SMART_DIM *pSmart, char *str)
+{
+	str[30] = VT_300CD_R_20;
+	str[31] = VT_300CD_G_20;
+	str[32] = VT_300CD_B_20;
+}
+
+enum magna_octa_voltage_level {
+	MAGNA_OCTA_LEVEL_0,
+	MAGNA_OCTA_LEVEL_3,
+	MAGNA_OCTA_LEVEL_11,
+	MAGNA_OCTA_LEVEL_23,
+	MAGNA_OCTA_LEVEL_35,
+	MAGNA_OCTA_LEVEL_51,
+	MAGNA_OCTA_LEVEL_87,
+	MAGNA_OCTA_LEVEL_151,
+	MAGNA_OCTA_LEVEL_203,
+	MAGNA_OCTA_LEVEL_255,
+};
+
+struct magna_octa_rgb_triplet {
+	char r;
+	char g;
+	char b;
+};
+
+enum magna_octa_color_channel {
+	MAGNA_OCTA_RED,
+	MAGNA_OCTA_GREEN,
+	MAGNA_OCTA_BLUE,
+};
+
+static int *magna_octa_voltage_slot(struct GAMMA_LEVEL *voltage,
+				    enum magna_octa_voltage_level level)
+{
+	switch (level) {
+	case MAGNA_OCTA_LEVEL_0:
+		return &voltage->level_0;
+	case MAGNA_OCTA_LEVEL_3:
+		return &voltage->level_3;
+	case MAGNA_OCTA_LEVEL_11:
+		return &voltage->level_11;
+	case MAGNA_OCTA_LEVEL_23:
+		return &voltage->level_23;
+	case MAGNA_OCTA_LEVEL_35:
+		return &voltage->level_35;
+	case MAGNA_OCTA_LEVEL_51:
+		return &voltage->level_51;
+	case MAGNA_OCTA_LEVEL_87:
+		return &voltage->level_87;
+	case MAGNA_OCTA_LEVEL_151:
+		return &voltage->level_151;
+	case MAGNA_OCTA_LEVEL_203:
+		return &voltage->level_203;
+	case MAGNA_OCTA_LEVEL_255:
+		return &voltage->level_255;
+	}
+
+	return NULL;
+}
+
+static int magna_octa_gray_index(enum magna_octa_voltage_level level)
+{
+	switch (level) {
+	case MAGNA_OCTA_LEVEL_3:
+		return V3_INDEX;
+	case MAGNA_OCTA_LEVEL_11:
+		return V11_INDEX;
+	case MAGNA_OCTA_LEVEL_23:
+		return V23_INDEX;
+	case MAGNA_OCTA_LEVEL_35:
+		return V35_INDEX;
+	case MAGNA_OCTA_LEVEL_51:
+		return V51_INDEX;
+	case MAGNA_OCTA_LEVEL_87:
+		return V87_INDEX;
+	case MAGNA_OCTA_LEVEL_151:
+		return V151_INDEX;
+	case MAGNA_OCTA_LEVEL_203:
+		return V203_INDEX;
+	case MAGNA_OCTA_LEVEL_255:
+		return V255_INDEX;
+	case MAGNA_OCTA_LEVEL_0:
+	default:
+		return -1;
+	}
+}
+
+static int magna_octa_table_gray(struct SMART_DIM *pSmart, int *index,
+				 enum magna_octa_voltage_level level,
+				 enum magna_octa_color_channel channel)
+{
+	struct GRAY_VOLTAGE *gray;
+
+	gray = &pSmart->GRAY.TABLE[index[magna_octa_gray_index(level)]];
+
+	switch (channel) {
+	case MAGNA_OCTA_RED:
+		return gray->R_Gray;
+	case MAGNA_OCTA_GREEN:
+		return gray->G_Gray;
+	case MAGNA_OCTA_BLUE:
+	default:
+		return gray->B_Gray;
+	}
+}
+
+static int magna_octa_top_gray(struct SMART_DIM *pSmart, bool use_vreg0,
+			       enum magna_octa_color_channel channel)
+{
+	if (use_vreg0)
+		return S6E8FA_VREG0_REF;
+
+	switch (channel) {
+	case MAGNA_OCTA_RED:
+		return pSmart->GRAY.VT_TABLE.R_Gray;
+	case MAGNA_OCTA_GREEN:
+		return pSmart->GRAY.VT_TABLE.G_Gray;
+	case MAGNA_OCTA_BLUE:
+	default:
+		return pSmart->GRAY.VT_TABLE.B_Gray;
+	}
+}
+
+static int magna_octa_adjust_mid_voltage(int mtp_offset, int base_value,
+					 int top_gray, int lower_voltage)
+{
+	unsigned long long delta, scale, product;
+
+	delta = top_gray - lower_voltage;
+	scale = (MAGNA_OCTA_MID_COEFFICIENT + mtp_offset + base_value)
+		<< BIT_SHIFT;
+	do_div(scale, MAGNA_OCTA_MID_DENOMINATOR);
+	product = (delta * scale) >> BIT_SHIFT;
+
+	return top_gray - product;
+}
+
+static void magna_octa_adjust_mid_rgb(struct SMART_DIM *pSmart,
+				      enum magna_octa_voltage_level target,
+				      enum magna_octa_voltage_level lower,
+				      struct magna_octa_rgb_triplet base,
+				      struct magna_octa_rgb_triplet offsets)
+{
+	*magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.R_VOLTAGE, target) =
+		magna_octa_adjust_mid_voltage(char_to_int(offsets.r), base.r,
+					      pSmart->GRAY.VT_TABLE.R_Gray,
+					      *magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.R_VOLTAGE, lower));
+	*magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.G_VOLTAGE, target) =
+		magna_octa_adjust_mid_voltage(char_to_int(offsets.g), base.g,
+					      pSmart->GRAY.VT_TABLE.G_Gray,
+					      *magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.G_VOLTAGE, lower));
+	*magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.B_VOLTAGE, target) =
+		magna_octa_adjust_mid_voltage(char_to_int(offsets.b), base.b,
+					      pSmart->GRAY.VT_TABLE.B_Gray,
+					      *magna_octa_voltage_slot(&pSmart->RGB_OUTPUT.B_VOLTAGE, lower));
+}
+
+static u8 magna_octa_make_mid_hexa(int top_gray, int target_gray, int upper_gray)
+{
+	unsigned long long delta, scaled, range;
+
+	delta = top_gray - target_gray;
+	scaled = delta * MAGNA_OCTA_MID_DENOMINATOR;
+	range = top_gray - upper_gray;
+	do_div(scaled, range);
+
+	return (scaled - MAGNA_OCTA_MID_COEFFICIENT) & 0xff;
+}
+
+static void magna_octa_write_mid_hexa(struct SMART_DIM *pSmart, int *index,
+				      char *str, int offset,
+				      enum magna_octa_voltage_level target,
+				      enum magna_octa_voltage_level upper,
+				      bool use_vreg0_top)
+{
+	str[offset] = magna_octa_make_mid_hexa(
+		magna_octa_top_gray(pSmart, use_vreg0_top, MAGNA_OCTA_RED),
+		magna_octa_table_gray(pSmart, index, target, MAGNA_OCTA_RED),
+		magna_octa_table_gray(pSmart, index, upper, MAGNA_OCTA_RED));
+	str[offset + 1] = magna_octa_make_mid_hexa(
+		magna_octa_top_gray(pSmart, use_vreg0_top, MAGNA_OCTA_GREEN),
+		magna_octa_table_gray(pSmart, index, target, MAGNA_OCTA_GREEN),
+		magna_octa_table_gray(pSmart, index, upper, MAGNA_OCTA_GREEN));
+	str[offset + 2] = magna_octa_make_mid_hexa(
+		magna_octa_top_gray(pSmart, use_vreg0_top, MAGNA_OCTA_BLUE),
+		magna_octa_table_gray(pSmart, index, target, MAGNA_OCTA_BLUE),
+		magna_octa_table_gray(pSmart, index, upper, MAGNA_OCTA_BLUE));
+}
+
+static int v203_adjustment(struct SMART_DIM *pSmart)
+{
+	magna_octa_adjust_mid_rgb(pSmart, MAGNA_OCTA_LEVEL_203,
+				  MAGNA_OCTA_LEVEL_255,
+				  (struct magna_octa_rgb_triplet) {
+					  V203_300CD_R_20,
+					  V203_300CD_G_20,
+					  V203_300CD_B_20,
+				  },
+				  (struct magna_octa_rgb_triplet) {
+					  pSmart->MTP.R_OFFSET.OFFSET_203,
+					  pSmart->MTP.G_OFFSET.OFFSET_203,
+					  pSmart->MTP.B_OFFSET.OFFSET_203,
+				  });
+
+
+	return 0;
+
+}
+
+static void v203_hexa(int *index, struct SMART_DIM *pSmart, char *str)
+{
+	magna_octa_write_mid_hexa(pSmart, index, str, 6,
+				  MAGNA_OCTA_LEVEL_203,
+				  MAGNA_OCTA_LEVEL_255,
+				  false);
+}
