+void msm_devfreq_hw_init(struct msm_gpu *gpu)
+{
+	struct msm_gpu_devfreq *df = &gpu->devfreq;
+	unsigned long sample_rate;
+
+	if (!has_devfreq(gpu))
+		return;
+
+	mutex_lock(&df->lock);
+	if (!df->suspended) {
+		df->busy_cycles = gpu->funcs->gpu_busy(gpu, &sample_rate);
+		df->time = ktime_get();
+	}
+	mutex_unlock(&df->lock);
+}
