arch="armv7"
options="!check !archcheck"
depends="
	linux-quanta-narnia
	postmarketos-base
	postmarketos-base-downstream
	mkbootimg
	mtk-mkimage
	firmware-quanta-narnia
	quanta-narnia-wifi-loader
	msm-fb-refresher
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	00-fbdev-rotate.conf
	modules-initfs
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm644 "$srcdir"/00-fbdev-rotate.conf \
		"$pkgdir"/usr/share/X11/xorg.conf.d/00-fbdev-rotate.conf
}

