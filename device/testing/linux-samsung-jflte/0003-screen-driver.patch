+char offset_cal(int offset,  char value)
+{
+	unsigned char real_value;
+
+	if (value < 0 )
+		real_value = value * -1;
+	else
+		real_value = value;
+
+	if (real_value - offset < 0)
+		return 0;
+	else if (real_value - offset > 255)
+		return 0xFF;
+	else
+		return real_value - offset;
+}
