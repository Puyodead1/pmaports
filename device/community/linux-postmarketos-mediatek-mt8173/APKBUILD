a33f9cbc3dece24ba1dcfaee2451c9527c782826e05632103c47ff7c36a21384bbe46da3133235eccdbfac5604bc5d731f68b32feeef2e9a77d429be4d687ddf  config-postmarketos-mediatek-mt8173.aarch64
"
