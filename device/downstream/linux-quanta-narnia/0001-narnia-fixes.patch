+/* Ties fbcon's VT blank/unblank (console idle timeout, or explicit
+ * FBIOBLANK ioctl) to the actual backlight hardware, which mtkfb
+ * otherwise leaves completely untouched. Deliberately goes through
+ * disp_bls_set_backlight()/disp_bls_get_backlight() only - the same
+ * authoritative entry point the "lcd-backlight" LED classdev uses
+ * (see cust_leds.c: MT65XX_LED_MODE_CUST_BLS_PWM) - rather than
+ * duplicating panel/PWM register access here.
+ */
+static unsigned int mtkfb_blank_saved_level;
+static bool mtkfb_is_blanked;
+
+static int mtkfb_blank(int blank, struct fb_info *info)
+{
+    if (blank == FB_BLANK_UNBLANK) {
+        /* Guard against a spurious initial unblank (e.g. at fbcon
+         * registration) restoring a level we never actually saved.
+         */
+        if (mtkfb_is_blanked) {
+            disp_bls_set_backlight(mtkfb_blank_saved_level);
+            mtkfb_is_blanked = false;
+        }
+    } else if (!mtkfb_is_blanked) {
+        mtkfb_blank_saved_level = disp_bls_get_backlight();
+        disp_bls_set_backlight(0);
+        mtkfb_is_blanked = true;
+    }
+    return 0;
+}
+
 /* Callback table for the frame buffer framework. Some of these pointers
  * will be changed according to the current setting of fb_info->accel_flags.
  */
