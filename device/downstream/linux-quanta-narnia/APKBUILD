# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config based on: arch/arm/configs/narnia_defconfig

maintainer="Puyodead1"
pkgname=linux-quanta-narnia
pkgver=3.10.108
pkgrel=0
pkgdesc="LeapFrog Epic Academy V3 Kernel"
arch="armv7"
_carch="arm"
_flavor="quanta-narnia"
url="https://github.com/mt8127-tadpole/android_kernel_mediatek_mt8127-common"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	devicepkg-dev
	findutils
	flex
	openssl-dev
	perl
	gcc4
	linux-headers
	xz
"

# Compiler: GCC 4 (doesn't compile with versions above GCC 4)
if ! echo "${CC:-}" | grep -q '^gcc4-'; then
    CC="gcc4-$CC"
    HOSTCC="gcc4-gcc"
    CROSS_COMPILE="gcc4-$CROSS_COMPILE"
fi


# Source
_repository="android_kernel_mediatek_mt8127-common"
_commit="3a1251cdbaebe4727e87548e5e1c22dd7e23cdae"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_commit.tar.gz::https://github.com/mt8127-tadpole/$_repository/archive/$_commit.tar.gz
	$_config
	0001-narnia-fixes.patch
"

# silence-usb-logspam.patch
# silence-cmb-logspam.patch
# silence-tz-logspam.patch
# silence-thermal-logspam.patch


builddir="$srcdir/$_repository-$_commit"
_outdir="out"

prepare() {
	default_prepare
	. downstreamkernel_prepare
}

build() {
	unset LDFLAGS
	make O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	downstreamkernel_package "$builddir" "$pkgdir" "$_carch" \
		"$_flavor" "$_outdir"
}

