+static int magna_octa_evt1_bl_level(int brightness_level)
+{
+	int i;
+
+	if (brightness_level > AOR_FIX_CD)
+		return brightness_level;
+
+	if (brightness_level < AOR_ADJUST_CD)
+		return AOR_ADJUST_CD;
+
+	for (i = 0; i < ARRAY_SIZE(magna_octa_evt1_bl_remap); i++)
+		if (magna_octa_evt1_bl_remap[i].input == brightness_level)
+			return magna_octa_evt1_bl_remap[i].output;
+
+	return 263;
+}
+
+static const int *magna_octa_evt1_candela_coeff(int brightness_level)
+{
+	if (brightness_level <= 300 && brightness_level >= 195)
+		return candela_coeff_1p85;
+
+	if (brightness_level <= 183 && brightness_level >= 111)
+		return candela_coeff_1p8;
+
+	if (brightness_level <= 105 && brightness_level >= 87)
+		return candela_coeff_1p85;
+
+	if (brightness_level <= 82 && brightness_level >= 68)
+		return candela_coeff_1p8;
+
+	if (brightness_level <= 64 && brightness_level >= 44)
+		return candela_coeff_1p75;
+
+	if (brightness_level <= 41 && brightness_level >= 24)
+		return candela_coeff_1p7;
+
+	if (brightness_level <= 22 && brightness_level >= 13)
+		return candela_coeff_1p65;
+
+	if (brightness_level <= 12 && brightness_level >= 10)
+		return candela_coeff_1p6;
+
+	return candela_coeff_2p2;
+}
+
+static void magna_octa_fill_candela_level(long long *candela_level,
+					  int bl_level, const int *coeff)
+{
+	int cnt, point_index;
+
+	for (cnt = 0; cnt < S6E8FA_TABLE_MAX; cnt++) {
+		point_index = S6E8FA_ARRAY[cnt + 1];
+		candela_level[cnt] = (long long)coeff[point_index] * bl_level;
+	}
+}
+
+int find_cadela_table(int brightness)
+{
+	int loop;
+	int err = -1;
+
+	for(loop = 0; loop <= CCG6_MAX_TABLE; loop++)
+		if (ccg6_candela_table[loop][0] == brightness)
+			return ccg6_candela_table[loop][1];
+
+	return err;
+}
