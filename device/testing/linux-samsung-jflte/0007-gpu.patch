+static int a3xx_bus_clear_pending_transactions(struct msm_gpu *gpu)
+{
+	unsigned long timeout;
+	u32 ack, clock_ctl;
+	int ret = -ETIMEDOUT;
+
+	clock_ctl = gpu_read(gpu, REG_A3XX_RBBM_CLOCK_CTL);
+	gpu_write(gpu, REG_A3XX_RBBM_CLOCK_CTL, 0);
+	gpu_read(gpu, REG_A3XX_RBBM_CLOCK_CTL);
+
+	gpu_write(gpu, REG_A3XX_VBIF_XIN_HALT_CTRL0,
+		  A3XX_VBIF_XIN_HALT_CTRL0_MASK);
+	timeout = jiffies + msecs_to_jiffies(100);
+	do {
+		ack = gpu_read(gpu, REG_A3XX_VBIF_XIN_HALT_CTRL1);
+		if ((ack & A3XX_VBIF_XIN_HALT_CTRL0_MASK) ==
+		    A3XX_VBIF_XIN_HALT_CTRL0_MASK) {
+			ret = 0;
+			break;
+		}
+	} while (time_before(jiffies, timeout));
+	gpu_write(gpu, REG_A3XX_VBIF_XIN_HALT_CTRL0, 0);
+	gpu_write(gpu, REG_A3XX_RBBM_CLOCK_CTL, clock_ctl);
+
+	if (ret) {
+		dev_err(gpu->dev->dev,
+			"VBIF drain timed out: ack=%#x mask=%#x clock_ctl=%#x\n",
+			ack, A3XX_VBIF_XIN_HALT_CTRL0_MASK, clock_ctl);
+		return -EBUSY;
+	}
+
+	return 0;
+}
+
+static int a3xx_pm_suspend(struct msm_gpu *gpu)
+{
+	int ret;
+
+	if (!a3xx_idle(gpu)) {
+		dev_err(gpu->dev->dev,
+			"suspend idle check failed: rbbm_status=%#x ring_rptr=%#x ring_wptr=%#x\n",
+			gpu_read(gpu, REG_A3XX_RBBM_STATUS),
+			gpu_read(gpu, REG_AXXX_CP_RB_RPTR),
+			gpu_read(gpu, REG_AXXX_CP_RB_WPTR));
+		return -EBUSY;
+	}
+
+	ret = a3xx_bus_clear_pending_transactions(gpu);
+	if (ret) {
+		dev_err(gpu->dev->dev,
+			"VBIF drain status unavailable, resetting before suspend\n");
+		gpu_write(gpu, REG_A3XX_RBBM_SW_RESET_CMD, 1);
+		gpu_read(gpu, REG_A3XX_RBBM_SW_RESET_CMD);
+		gpu_write(gpu, REG_A3XX_RBBM_SW_RESET_CMD, 0);
+	}
+
+	return msm_gpu_pm_suspend(gpu);
+}
