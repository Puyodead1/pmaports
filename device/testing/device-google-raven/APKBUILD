maintainer="Ingo Reitz <9l@9lo.re>"
pkgname=device-google-raven
pkgdesc="Google Pixel 6 Pro"
pkgver=6
pkgrel=1
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	android-tools
	linux-postmarketos-gs101
	postmarketos-base
	soc-google-gs101
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-phosh:phosh
	$pkgname-usb-network:usb_network
"
source="
	90-device-google-raven.preset
	deviceinfo
	kernel-cmdline.conf
	modules-initfs
	phoc.ini
	phosh-osk-raven.gschema.override
	raven-usb-network
	raven-usb-network.service
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

phosh() {
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-ui-phosh"
	install -Dm644 "$srcdir"/phoc.ini "$subpkgdir"/etc/phosh/phoc.ini
	install -Dm644 "$srcdir"/phosh-osk-raven.gschema.override \
		"$subpkgdir"/usr/share/glib-2.0/schemas/90-phosh-osk-raven.gschema.override
}

usb_network() {
	pkgdesc="USB network recovery helper for Google Pixel 6 Pro"
	depends="postmarketos-usb-moded-systemd"
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-usb-moded-systemd"

	install -Dm644 "$srcdir"/raven-usb-network.service \
		"$subpkgdir"/usr/lib/systemd/system/raven-usb-network.service
	install -Dm755 "$srcdir"/raven-usb-network \
		"$subpkgdir"/usr/bin/raven-usb-network
	install -Dm644 "$srcdir"/90-device-google-raven.preset \
		"$subpkgdir"/usr/lib/systemd/system-preset/90-device-google-raven.preset
}

