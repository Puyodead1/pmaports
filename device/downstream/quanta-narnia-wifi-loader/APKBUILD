maintainer="Puyodead1 <23562356riley@gmail.com>"
pkgname=quanta-narnia-wifi-loader
pkgver=1
pkgrel=0
pkgdesc="LeapFrog EpicV3 (quanta-narnia) WiFi/BT/GPS combo-chip loader (wmt_loader + 6620_launcher)"
url="https://github.com/Puyodead1/wmt"
arch="armv7"
license="custom"
options="!check !archcheck"
depends="
	openrc
	firmware-quanta-narnia
"
makedepends="linux-headers"
install="$pkgname.post-install"
source="
	wmt_loader.c
	stp_uart_launcher.c
	wmt_ioctl.h
	$pkgname.initd
"

build() {
	${CC:-cc} -static -o wmt_loader wmt_loader.c
	${CC:-cc} -static -o 6620_launcher stp_uart_launcher.c -lpthread
}

package() {
	install -Dm755 wmt_loader "$pkgdir/usr/bin/wmt_loader"
	install -Dm755 6620_launcher "$pkgdir/usr/bin/6620_launcher"
	install -Dm755 "$srcdir/$pkgname.initd" "$pkgdir/etc/init.d/$pkgname"
}

