# overwrites/appends its own cmdline regardless of what's embedded here.
# Use CONFIG_CMDLINE (with CONFIG_CMDLINE_EXTEND=y) in the kernel config
# instead if you need to actually change the boot cmdline.
deviceinfo_kernel_cmdline="console=ttyMT0,921600n1 printk.disable_uart=0 root=/dev/ram fbcon=rotate:2"
