maintainer="Puyodead1 <23562356riley@gmail.com>"
pkgname=firmware-quanta-narnia
pkgver=1
pkgrel=1
pkgdesc="LeapFrog EpicV3 (quanta-narnia) WiFi/BT/GPS combo-chip firmware"
url="https://github.com/Puyodead1/wmt"
arch="armv7"
license="proprietary"
options="!check !archcheck !strip pmb:cross-native"
source="
	WIFI_RAM_CODE
	WIFI_RAM_CODE_8127
	WIFI_RAM_CODE_E6
	WIFI_RAM_CODE_MT6628
	WIFI_RAM_CODE_MT6630
	mt6571_patch_e1_0_hdr.bin
	mt6571_patch_e1_1_hdr.bin
	WMT_SOC.cfg
	wifi.cfg
	nvram.bin
"

package() {
	for _i in WIFI_RAM_CODE WIFI_RAM_CODE_8127 WIFI_RAM_CODE_E6 \
		WIFI_RAM_CODE_MT6628 WIFI_RAM_CODE_MT6630 \
		mt6571_patch_e1_0_hdr.bin mt6571_patch_e1_1_hdr.bin \
		WMT_SOC.cfg wifi.cfg; do
		install -Dm644 "$srcdir/$_i" "$pkgdir/usr/lib/firmware/$_i"
	done
	install -Dm644 "$srcdir/nvram.bin" \
		"$pkgdir/data/nvram/APCFG/APRDEB/WIFI"
}

